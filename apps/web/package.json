{
  "name": "web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:rolldown": "node ../../node_modules/rolldown-vite/bin/vite.js build",
    "analyze:bundle": "ANALYZE_BUNDLE=1 vite build",
    "analyze:bundle:rolldown": "ANALYZE_BUNDLE=1 node ../../node_modules/rolldown-vite/bin/vite.js build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "check-types": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "cd ../.. && biome check --config-path biome.json apps/web",
    "lint:fix": "cd ../.. && biome check --config-path biome.json apps/web --write",
    "dev": "vite dev",
    "dev:vite": "vite dev",
    "dev:rolldown": "node ../../node_modules/rolldown-vite/bin/vite.js dev",
    "profile:vite": "vite --profile",
    "debug:transform": "vite --debug transform",
    "debug:plugin-transform": "vite --debug plugin-transform",
    "test:bundle-size": "bun run build && size-limit && node ./scripts/check-page-size.mjs",
    "test:bundle-size:rolldown": "bun run build:rolldown && size-limit && node ./scripts/check-page-size.mjs",
    "test:deps": "knip --production --dependencies",
    "test:perf": "PLAYWRIGHT_MANAGED_SERVERS=1 PLAYWRIGHT_REUSE_SERVERS=1 playwright test -c playwright.e2e.config.ts e2e/performance.spec.ts",
    "test:frontend:dev": "PLAYWRIGHT_MANAGED_SERVERS=1 PLAYWRIGHT_REUSE_SERVERS=1 playwright test -c playwright.e2e.config.ts",
    "test:frontend:dev:ui": "PLAYWRIGHT_MANAGED_SERVERS=1 PLAYWRIGHT_REUSE_SERVERS=1 playwright test -c playwright.e2e.config.ts --ui"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.4.18",
    "@my-app/ai-chat": "*",
    "@my-app/assistant": "*",
    "@my-app/ui": "*",
    "@lucide/svelte": "^0.561.0",
    "@orpc/client": "^1.13.4",
    "@orpc/tanstack-query": "^1.12.2",
    "@tanstack/svelte-form": "^1.19.2",
    "@tanstack/svelte-query": "^5.85.3",
    "better-auth": "^1.4.18",
    "better-auth-telegram": "^0.3.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@my-app/api-contract": "*",
    "@my-app/config": "*",
    "@orpc/server": "^1.13.4",
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.31.1",
    "@sveltejs/vite-plugin-svelte": "^6.1.2",
    "@tailwindcss/vite": "^4.1.12",
    "@size-limit/file": "^12.0.0",
    "@tanstack/svelte-query-devtools": "^5.85.3",
    "knip": "^5.85.0",
    "size-limit": "^12.0.0",
    "svelte": "^5.38.1",
    "svelte-check": "^4.3.1",
    "tailwindcss": "^4.1.12",
    "typescript": "^5",
    "ultracite": "^7.2.3",
    "vite": "^7.1.2",
    "vite-bundle-analyzer": "^1.3.6",
    "rolldown-vite": "7.3.1"
  }
}
