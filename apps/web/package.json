{
  "name": "web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "check-types": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "cd ../.. && biome check --config-path biome.json apps/web",
    "lint:fix": "cd ../.. && biome check --config-path biome.json apps/web --write",
    "dev:vite": "vite dev",
    "test:frontend:dev": "PLAYWRIGHT_MANAGED_SERVERS=1 PLAYWRIGHT_REUSE_SERVERS=1 playwright test -c playwright.e2e-dev.config.ts",
    "test:frontend:dev:ui": "PLAYWRIGHT_MANAGED_SERVERS=1 PLAYWRIGHT_REUSE_SERVERS=1 playwright test -c playwright.e2e-dev.config.ts --ui"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.4.18",
    "@full-stack-cf-app/ai-chat": "*",
    "@full-stack-cf-app/api": "*",
    "@full-stack-cf-app/assistant": "*",
    "@full-stack-cf-app/auth": "*",
    "@full-stack-cf-app/env": "*",
    "@full-stack-cf-app/ui": "*",
    "@internationalized/date": "^3.11.0",
    "@libsql/client": "0.15.15",
    "@lucide/svelte": "^0.561.0",
    "@orpc/tanstack-query": "^1.12.2",
    "@tanstack/svelte-form": "^1.19.2",
    "@tanstack/svelte-query": "^5.85.3",
    "better-auth": "^1.4.18",
    "better-auth-telegram": "^0.3.2",
    "dotenv": "^17.2.2",
    "libsql": "0.5.22",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@full-stack-cf-app/config": "*",
    "@orpc/client": "^1.13.4",
    "@orpc/server": "^1.13.4",
    "@sveltejs/adapter-auto": "^6.1.0",
    "@sveltejs/adapter-cloudflare": "^7.2.4",
    "@sveltejs/kit": "^2.31.1",
    "@sveltejs/vite-plugin-svelte": "^6.1.2",
    "@tailwindcss/vite": "^4.1.12",
    "@tanstack/svelte-query-devtools": "^5.85.3",
    "alchemy": "^0.82.1",
    "svelte": "^5.38.1",
    "svelte-check": "^4.3.1",
    "tailwindcss": "^4.1.12",
    "typescript": "^5",
    "ultracite": "^7.1.3",
    "vite": "^7.1.2"
  }
}
