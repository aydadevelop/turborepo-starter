---
import BaseLayout from "../layouts/base-layout.astro";
---

<BaseLayout pageTags={["pricing"]} title="Pricing | Mary Gold Studio">
	<section class="grid two">
		<div class="panel">
			<p class="kicker">Offer</p>
			<h2>Clarity Sprint</h2>
			<p>
				A one-week engagement for founders who need immediate message clarity
				before a launch or investor round.
			</p>
			<p><strong>Starting at $2,500</strong></p>
		</div>
		<div class="panel">
			<p class="kicker">Offer</p>
			<h2>Lead Engine Build</h2>
			<p>
				Strategy, website messaging, qualification flow, and booking automation
				for founder-led teams that are ready to systemize inbound.
			</p>
			<p><strong>Starting at $7,500</strong></p>
		</div>
	</section>
</BaseLayout>
