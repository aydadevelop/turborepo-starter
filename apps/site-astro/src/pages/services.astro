---
import BaseLayout from "../layouts/base-layout.astro";
---

<BaseLayout pageTags={["services"]} title="Services | Mary Gold Studio">
	<section class="grid two">
		<div class="panel">
			<p class="kicker">Service one</p>
			<h2>Messaging sprints</h2>
			<p>
				Clarify ICP, offer framing, landing page narrative, and demo call
				structure in one focused sprint.
			</p>
		</div>
		<div class="panel">
			<p class="kicker">Service two</p>
			<h2>Launch systems</h2>
			<p>
				Build the lead journey from first visit through qualification, booking,
				and follow-up automation.
			</p>
		</div>
	</section>
</BaseLayout>
