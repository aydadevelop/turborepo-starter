---
import BaseLayout from "../layouts/base-layout.astro";
---

<BaseLayout pageTags={["faq"]} title="FAQ | Mary Gold Studio">
	<section class="grid">
		<div class="panel">
			<h2>FAQ</h2>
			<p><strong>Do you only work with B2B founders?</strong></p>
			<p>
				Mostly. The sweet spot is founder-led B2B, boutique agencies, and
				consulting offers with a higher-ticket sales process.
			</p>
			<p><strong>What do you need from us?</strong></p>
			<p>
				Customer interviews, current site copy, and clarity on company size,
				market, and ideal customer profile.
			</p>
		</div>
	</section>
</BaseLayout>
