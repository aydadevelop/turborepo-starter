---
const {
	description = "Founder-led positioning and conversion site used for widget embedding and scrape-prefill demos.",
	pageTags = [],
	title = "Mary Gold Studio",
} = Astro.props;

const widgetUrl = import.meta.env.PUBLIC_WIDGET_URL || "http://localhost:5174";
const widgetConfigId =
	import.meta.env.PUBLIC_WIDGET_DEMO_CONFIG_ID || "ctly-demo-founder";
const widgetTags = ["astro-site", "founder-led", ...pageTags]
	.map((tag) => String(tag).trim())
	.filter(Boolean);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>{title}</title>
		<meta name="description" content={description}>
		<style>
			:root {
				font-family: "IBM Plex Sans", ui-sans-serif, system-ui, sans-serif;
				color: #0f172a;
				color-scheme: light;
				background: #f4f7f5;
			}
			body {
				margin: 0;
				background:
					radial-gradient(
						circle at top,
						rgba(16, 185, 129, 0.18),
						transparent 32%
					),
					#f4f7f5;
			}
			a {
				color: inherit;
				text-decoration: none;
			}
			main {
				max-width: 1120px;
				padding: 40px 24px 96px;
				margin: 0 auto;
			}
			header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding-bottom: 24px;
			}
			nav {
				display: flex;
				gap: 16px;
				font-size: 14px;
				color: #475569;
			}
			.hero,
			.panel,
			.callout {
				background: rgba(255, 255, 255, 0.88);
				border: 1px solid rgba(15, 23, 42, 0.08);
				border-radius: 28px;
				box-shadow: 0 20px 60px rgba(15, 23, 42, 0.08);
			}
			.hero {
				display: grid;
				grid-template-columns: 1.3fr 0.9fr;
				gap: 28px;
				padding: 36px;
			}
			.grid {
				display: grid;
				gap: 20px;
			}
			.grid.two {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
			.panel {
				padding: 24px;
			}
			.kicker {
				font-size: 12px;
				font-weight: 700;
				color: #15803d;
				text-transform: uppercase;
				letter-spacing: 0.22em;
			}
			h1,
			h2,
			h3 {
				margin: 0;
				line-height: 1.05;
			}
			h1 {
				font-size: clamp(2.8rem, 7vw, 5rem);
			}
			h2 {
				font-size: clamp(2rem, 4vw, 2.8rem);
			}
			p {
				line-height: 1.6;
				color: #334155;
			}
			.stats {
				display: flex;
				flex-wrap: wrap;
				gap: 14px;
				margin-top: 24px;
			}
			.stat {
				min-width: 140px;
				padding: 14px 16px;
				background: #f8fafc;
				border-radius: 18px;
			}
			.widget-callout {
				margin-top: 28px;
			}
			.widget-callout > div {
				min-height: 680px;
			}
			.footer-note {
				margin-top: 28px;
				font-size: 14px;
				color: #64748b;
			}
			@media (max-width: 900px) {
				.hero,
				.grid.two {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<main>
			<header>
				<div>
					<div class="kicker">Mary Gold Studio</div>
					<strong>Founder-led positioning and launch systems</strong>
				</div>
				<nav>
					<a href="/">Home</a>
					<a href="/services">Services</a>
					<a href="/pricing">Pricing</a>
					<a href="/faq">FAQ</a>
				</nav>
			</header>
			<slot />
			<p class="footer-note">
				This Astro site is intentionally content-rich so Contaktly can scrape it
				and prefill widget messaging, starter cards, and qualification rules.
			</p>
		</main>
		<script
			is:inline
			src={`${widgetUrl}/loader.js`}
			data-params={widgetConfigId}
			data-tags={widgetTags.join(",")}
		></script>
	</body>
</html>
