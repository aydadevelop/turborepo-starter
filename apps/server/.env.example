# Server Environment Variables
# Copy this file to .env for local development

# =============================================================================
# REQUIRED - Auth (Better Auth)
# =============================================================================
# Secret key for signing sessions/tokens. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-here

# Base URL for the auth server (matches your server URL)
BETTER_AUTH_URL=http://localhost:3000

# =============================================================================
# REQUIRED - CORS
# =============================================================================
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176

# =============================================================================
# OPTIONAL - Payments (Polar.sh)
# Leave empty to disable payment features
# =============================================================================
# Get your access token from https://polar.sh/settings
POLAR_ACCESS_TOKEN=

# Your Polar product ID for checkout
POLAR_PRODUCT_ID=

# Redirect URL after successful checkout ({CHECKOUT_ID} is replaced automatically)
POLAR_SUCCESS_URL=http://localhost:5173/success?checkout_id={CHECKOUT_ID}

# =============================================================================
# OPTIONAL - Telegram Notifications
# Leave TELEGRAM_BOT_TOKEN empty to use local mock delivery behavior.
# =============================================================================
# Telegram bot token used for outbound notification delivery
TELEGRAM_BOT_TOKEN=

# Override Telegram API base URL when needed
TELEGRAM_BOT_API_BASE_URL=https://api.telegram.org

# =============================================================================
# OPTIONAL - Calendar Sync (Google)
# =============================================================================
# Service account JSON payload string used by server runtime for Google Calendar API
GOOGLE_CALENDAR_CREDENTIALS_JSON=

# Shared token expected in X-Goog-Channel-Token webhook header
GOOGLE_CALENDAR_WEBHOOK_SHARED_TOKEN=

# Bearer token for internal polling endpoint POST /internal/calendar/sync/google
CALENDAR_SYNC_TASK_TOKEN=
