# Server Environment Variables
# Copy this file to .env for local development

# =============================================================================
# REQUIRED - Auth (Better Auth)
# =============================================================================
# Secret key for signing sessions/tokens. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-here

# Base URL for the auth server (matches your server URL)
# For deploys: if omitted, infra derives from workers.dev subdomain when possible.
# SERVER_URL is the canonical source — BETTER_AUTH_URL is derived from it by Alchemy.
# Only set one of these; Alchemy sets both bindings automatically.
# SERVER_URL=http://localhost:3000
# BETTER_AUTH_URL=http://localhost:3000

# =============================================================================
# REQUIRED - CORS
# =============================================================================
# Comma-separated list of allowed origins
# For deploys: set explicitly to lock down origins, or allow infra to derive when
# CLOUDFLARE_WORKERS_SUBDOMAIN is available.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176

# =============================================================================
# OPTIONAL - Payments (Polar.sh)
# Leave empty to disable payment features
# =============================================================================
# Get your access token from https://polar.sh/settings
POLAR_ACCESS_TOKEN=

# Your Polar product ID for checkout
POLAR_PRODUCT_ID=

# Redirect URL after successful checkout ({CHECKOUT_ID} is replaced automatically)
POLAR_SUCCESS_URL=http://localhost:5173/success?checkout_id={CHECKOUT_ID}

# =============================================================================
# OPTIONAL - Telegram Notifications & Auth
# Leave TELEGRAM_BOT_TOKEN empty to use local mock delivery behavior.
# =============================================================================
# Telegram bot token used for outbound notification delivery and Telegram Login
TELEGRAM_BOT_TOKEN=

# Telegram bot username (without @) - required for Telegram Login Widget
TELEGRAM_BOT_USERNAME=

# Override Telegram API base URL when needed
TELEGRAM_BOT_API_BASE_URL=https://api.telegram.org

# =============================================================================
# OPTIONAL - Calendar Sync (Google)
# =============================================================================
# Service account JSON payload string used by server runtime for Google Calendar API
# To set up:
#   1. Place your google-calendar.credentials.json in apps/server/.secrets/
#   2. Run: node scripts/setup-google-calendar-env.mjs
#   3. Copy the output GOOGLE_CALENDAR_CREDENTIALS_JSON value below
# The .secrets/ folder is in .gitignore to prevent accidental commits
GOOGLE_CALENDAR_CREDENTIALS_JSON=

# Shared token expected in X-Goog-Channel-Token webhook header
GOOGLE_CALENDAR_WEBHOOK_SHARED_TOKEN=

# Bearer token for internal polling endpoint POST /internal/calendar/sync/google
CALENDAR_SYNC_TASK_TOKEN=

# =============================================================================
# OPTIONAL - Payments (CloudPayments)
# Leave empty to disable CloudPayments features
# =============================================================================
# Server-side webhook auth
CLOUDPAYMENTS_PUBLIC_ID=
CLOUDPAYMENTS_API_SECRET=

# Frontend widget (also set in apps/web/.env)
PUBLIC_CLOUDPAYMENTS_PUBLIC_ID=

# =============================================================================
# OPTIONAL - AI (OpenRouter)
# =============================================================================
# OpenRouter API key for AI assistant features
OPEN_ROUTER_API_KEY=

# AI model identifier (default: openai/gpt-5-nano:nitro)
AI_MODEL=
