{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "lint": "cd ../.. && biome check --config-path biome.json apps/server",
    "lint:fix": "cd ../.. && biome check --config-path biome.json apps/server --write",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server"
  },
  "dependencies": {
    "@my-app/api": "*",
    "@my-app/auth": "*",
    "@my-app/db": "*",
    "@my-app/env": "*",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "@orpc/openapi": "^1.12.2",
    "@orpc/server": "^1.12.2",
    "@orpc/zod": "^1.12.2",
    "ai": "^6.0.97",
    "better-auth": "^1.4.18",
    "dotenv": "^17.2.2",
    "hono": "^4.8.2",
    "ytdlp-nodejs": "^3.4.4",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@cloudflare/workers-types": "^4.20260228.0",
    "@my-app/config": "*",
    "@my-app/vitest-config": "*",
    "@types/node": "^22.19.11",
    "alchemy": "^0.85.1",
    "tsdown": "^0.16.5",
    "typescript": "^5",
    "ultracite": "^7.2.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.54.0"
  }
}
