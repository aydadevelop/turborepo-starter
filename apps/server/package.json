{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "dev": "bun --watch src/index.ts",
    "start:test": "bun src/index.ts",
    "check-types": "tsc -b",
    "lint": "cd ../.. && biome check --config-path biome.json apps/server",
    "lint:fix": "cd ../.. && biome check --config-path biome.json apps/server --write",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@my-app/api": "workspace:*",
    "@my-app/api-contract": "workspace:*",
    "@my-app/auth": "workspace:*",
    "@my-app/calendar": "workspace:*",
    "@my-app/db": "workspace:*",
    "@my-app/env": "workspace:*",
    "@my-app/notifications": "workspace:*",
    "@my-app/payment": "workspace:*",
    "@my-app/queue": "workspace:*",
    "@my-app/storage": "workspace:*",
    "@my-app/support": "workspace:*",
    "@my-app/events": "workspace:*",
    "@orpc/openapi": "^1.12.2",
    "@orpc/server": "^1.12.2",
    "@orpc/zod": "^1.12.2",
    "better-auth": "^1.5.0",
    "dotenv": "^17.2.2",
    "drizzle-orm": "1.0.0-beta.16-2ffd1a5",
    "hono": "^4.8.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@my-app/config": "workspace:*",
    "@my-app/vitest-config": "workspace:*",
    "@types/node": "^22.19.11",
    "tsdown": "^0.21.0",
    "typescript": "^5",
    "ultracite": "^7.2.3",
    "vitest": "^4.0.18"
  }
}
