{
  "name": "my-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "node scripts/ensure-db.mjs && set -a && . ./.env && set +a && turbo run dev --filter=server --filter=assistant --filter=notifications --filter=web",
    "build": "turbo run build",
    "build:rolldown": "turbo run build:rolldown --filter=web",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write",
    "check-types": "turbo run check-types",
    "analyze:bundle": "turbo run analyze:bundle --filter=web",
    "analyze:bundle:rolldown": "turbo run analyze:bundle:rolldown --filter=web",
    "test": "turbo run test",
    "test:bundle-size": "turbo run test:bundle-size --filter=web",
    "test:bundle-size:rolldown": "turbo run test:bundle-size:rolldown --filter=web",
    "test:deps": "turbo run test:deps --filter=web",
    "test:perf": "turbo run test:perf --filter=web",
    "test:watch": "turbo run test:watch",
    "test:e2e": "turbo run test:e2e --filter=@my-app/e2e-web",
    "test:e2e:reuse": "PLAYWRIGHT_MANAGED_SERVERS=0 turbo run test:e2e --filter=@my-app/e2e-web",
    "test:e2e:ui": "turbo run test:e2e:ui --filter=@my-app/e2e-web",
    "test:e2e:ui:reuse": "PLAYWRIGHT_MANAGED_SERVERS=0 turbo run test:e2e:ui --filter=@my-app/e2e-web",
    "dev:web": "turbo run dev:vite --filter=web",
    "dev:web:rolldown": "turbo run dev:rolldown --filter=web",
    "dev:server": "node scripts/ensure-db.mjs && set -a && . ./.env && set +a && turbo run dev --filter=server --filter=assistant --filter=notifications",
    "dev:server:clean": "bun run db:reset:local && bun run dev:server",
    "dev:infra": "node scripts/ensure-db.mjs",
    "db:push": "turbo run db:push --filter=@my-app/db",
    "db:migrate": "turbo run db:migrate --filter=@my-app/db",
    "db:generate": "TURBO_UI=false turbo run db:generate --filter=@my-app/db",
    "db:reset:local": "turbo run db:reset:local --filter=@my-app/db",
    "db:seed": "turbo run db:seed --filter=@my-app/db --",
    "db:studio": "turbo run db:studio --filter=@my-app/db",
    "e2e:clean": "node ./scripts/e2e-clean.mjs",
    "deploy:docker": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --pull always --wait",
    "destroy:docker": "docker compose -f docker-compose.yml -f docker-compose.prod.yml down -v",
    "deploy:docker:local": "docker compose up -d --wait",
    "check": "ultracite check",
    "ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@my-app/env": "*",
    "dotenv": "^17.3.1",
    "drizzle-orm": "1.0.0-beta.15-859cf75",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@my-app/config": "*",
    "@types/node": "^22.19.13",
    "turbo": "^2.8.12",
    "typescript": "^5.9.3",
    "ultracite": "7.2.3"
  },
  "packageManager": "bun@1.2.22",
  "overrides": {
    "drizzle-orm": "1.0.0-beta.15-859cf75"
  }
}
