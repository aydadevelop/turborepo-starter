{
  "name": "my-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun scripts/ensure-db.mjs && set -a && . ./.env && set +a && turbo run dev --filter=server --filter=assistant --filter=notifications --filter=web",
    "build": "turbo run build",
    "build:rolldown": "turbo run build:rolldown --filter=web",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write",
    "check-types": "turbo run check-types",
    "analyze:bundle": "turbo run analyze:bundle --filter=web",
    "analyze:bundle:rolldown": "turbo run analyze:bundle:rolldown --filter=web",
    "test": "turbo run test",
    "test:bundle-size": "turbo run test:bundle-size --filter=web",
    "test:bundle-size:rolldown": "turbo run test:bundle-size:rolldown --filter=web",
    "test:deps": "turbo run test:deps --filter=web",
    "test:perf": "turbo run test:perf --filter=web",
    "test:watch": "turbo run test:watch",
    "test:e2e": "turbo run test:e2e --filter=@my-app/e2e-web",
    "test:e2e:reuse": "PLAYWRIGHT_MANAGED_SERVERS=0 turbo run test:e2e --filter=@my-app/e2e-web",
    "test:e2e:external": "turbo run test:e2e:external --filter=@my-app/e2e-web",
    "test:e2e:ui:external": "turbo run test:e2e:ui:external --filter=@my-app/e2e-web",
    "test:e2e:ui": "turbo run test:e2e:ui --filter=@my-app/e2e-web",
    "test:e2e:ui:reuse": "PLAYWRIGHT_MANAGED_SERVERS=0 turbo run test:e2e:ui --filter=@my-app/e2e-web",
    "test:e2e:docker": "node ./scripts/e2e-docker-compose.mjs",
    "ci:preflight": "bunx turbo run build lint check-types test && bunx playwright install chromium && bun run test:e2e:docker",
    "dev:web": "turbo run dev:vite --filter=web",
    "dev:web:rolldown": "turbo run dev:rolldown --filter=web",
    "dev:server": "bun scripts/ensure-db.mjs && set -a && . ./.env && set +a && turbo run dev --filter=server --filter=assistant --filter=notifications",
    "dev:server:clean": "bun run db:reset:local && bun run dev:server",
    "dev:infra": "bun scripts/ensure-db.mjs",
    "dev:infra:obs": "docker compose --profile observability up -d",
    "db:push": "turbo run db:push --filter=@my-app/db",
    "db:migrate": "turbo run db:migrate --filter=@my-app/db",
    "db:generate": "TURBO_UI=false turbo run db:generate --filter=@my-app/db",
    "db:reset:local": "turbo run db:reset:local --filter=@my-app/db",
    "db:seed": "turbo run db:seed --filter=@my-app/db --",
    "db:studio": "turbo run db:studio --filter=@my-app/db",
    "e2e:clean": "node ./scripts/e2e-kill-ports.mjs",
    "deploy:docker:local": "docker compose --profile apps up -d --wait",
    "infra:preview": "cd infra/pulumi && pulumi preview",
    "infra:up": "cd infra/pulumi && pulumi up",
    "act:secrets": "bash infra/scripts/gen-act-secrets.sh",
    "act:deploy": "act -j deploy -W .github/workflows/deploy-docker.yml --container-architecture linux/amd64 --env DOCKER_API_VERSION=1.41",
    "act:deploy:dry": "act -j deploy -W .github/workflows/deploy-docker.yml --container-architecture linux/amd64 --env DOCKER_API_VERSION=1.41 -n",
    "check": "ultracite check",
    "ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@my-app/env": "workspace:*",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@my-app/config": "workspace:*",
    "@types/node": "^25.3.5",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3",
    "ultracite": "7.2.5"
  },
  "packageManager": "bun@1.3.10",
  "overrides": {
    "drizzle-orm": "1.0.0-beta.16-2ffd1a5",
    "better-auth": "^1.5.0",
    "@better-auth/core": "^1.5.0",
    "@better-auth/passkey": "^1.5.0"
  }
}
