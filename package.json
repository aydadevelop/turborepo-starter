{
  "name": "full-stack-cf-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/patch-deps.mjs",
    "dev": "turbo run dev --filter=@full-stack-cf-app/infra",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:e2e": "turbo run test:e2e",
    "test:integration:calendar": "turbo run test:integration:calendar --filter=@full-stack-cf-app/api",
    "test:integration:calendar:webhook": "turbo run test:integration:calendar:webhook --filter=@full-stack-cf-app/api",
    "test:integration:calendar:webhook:tunnel": "node ./scripts/calendar-webhook-e2e.mjs",
    "dev:native": "turbo run dev --filter=native",
    "dev:web": "turbo run dev:vite --filter=web",
    "dev:server": "turbo run dev --filter=@full-stack-cf-app/infra",
    "dev:server:e2e": "ALCHEMY_E2E=1 ALCHEMY_SKIP_WEB=1 STAGE=e2e SERVER_PORT=43100 NOTIFICATIONS_PORT=43101 ASSISTANT_PORT=43102 turbo run dev --filter=@full-stack-cf-app/infra",
    "dev:tunnel": "ALCHEMY_TUNNEL=1 turbo run dev --filter=@full-stack-cf-app/infra",
    "dev:server:clean": "npm run db:reset:local && npm run dev:server",
    "db:push": "turbo run db:push --filter=@full-stack-cf-app/db",
    "db:migrate": "turbo run db:migrate --filter=@full-stack-cf-app/db",
    "db:generate": "turbo run db:generate --filter=@full-stack-cf-app/db",
    "db:reset:local": "turbo run db:reset:local --filter=@full-stack-cf-app/db",
    "db:seed": "turbo run db:seed --filter=@full-stack-cf-app/db --",
    "db:studio": "turbo run db:studio --filter=@full-stack-cf-app/db",
    "db:backup:remote": "node ./scripts/d1-remote.mjs backup",
    "db:copy:remote": "node ./scripts/d1-remote.mjs copy",
    "deploy": "turbo run deploy --filter=@full-stack-cf-app/infra --",
    "deploy:dev": "npm run deploy -- --stage dev",
    "deploy:test": "npm run deploy -- --stage test",
    "deploy:prod": "npm run deploy -- --stage prod",
    "destroy": "turbo run destroy --filter=@full-stack-cf-app/infra --",
    "destroy:dev": "npm run destroy -- --stage dev",
    "destroy:test": "npm run destroy -- --stage test",
    "destroy:prod": "npm run destroy -- --stage prod",
    "check": "npm run lint && npm run check-types",
    "ruler:apply": "npx @intellectronica/ruler@latest apply --local-only"
  },
  "dependencies": {
    "@full-stack-cf-app/env": "*",
    "dotenv": "^17.2.2",
    "drizzle-orm": "1.0.0-beta.15-859cf75",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@cloudflare/workers-types": "^4.20251213.0",
    "@full-stack-cf-app/config": "*",
    "@types/node": "^22.13.14",
    "turbo": "^2.6.3",
    "typescript": "^5",
    "ultracite": "7.1.3"
  },
  "packageManager": "npm@11.7.0",
  "overrides": {
    "drizzle-orm": "1.0.0-beta.15-859cf75"
  }
}
