{
  "name": "my-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/patch-deps.mjs",
    "dev": "turbo run dev --filter=@my-app/infra",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:e2e": "turbo run test:e2e --filter=@my-app/e2e-web",
    "test:e2e:reuse": "PLAYWRIGHT_MANAGED_SERVERS=0 turbo run test:e2e --filter=@my-app/e2e-web",
    "test:e2e:ui": "turbo run test:e2e:ui --filter=@my-app/e2e-web",
    "test:e2e:ui:reuse": "PLAYWRIGHT_MANAGED_SERVERS=0 turbo run test:e2e:ui --filter=@my-app/e2e-web",
    "dev:web": "turbo run dev:vite --filter=web",
    "dev:server": "turbo run dev --filter=@my-app/infra",
    "dev:tunnel": "ALCHEMY_TUNNEL=1 turbo run dev --filter=@my-app/infra",
    "dev:server:clean": "bun run db:reset:local && bun run dev:server",
    "db:push": "turbo run db:push --filter=@my-app/db",
    "db:migrate": "turbo run db:migrate --filter=@my-app/db",
    "db:generate": "turbo run db:generate --filter=@my-app/db",
    "db:reset:local": "turbo run db:reset:local --filter=@my-app/db",
    "db:seed": "turbo run db:seed --filter=@my-app/db --",
    "db:studio": "turbo run db:studio --filter=@my-app/db",
    "db:backup:remote": "node ./scripts/d1-remote.mjs backup",
    "db:copy:remote": "node ./scripts/d1-remote.mjs copy",
    "deploy": "turbo run deploy --filter=@my-app/infra --",
    "deploy:dev": "bun run deploy -- --stage dev",
    "deploy:test": "bun run deploy -- --stage test",
    "deploy:prod": "bun run deploy -- --stage prod",
    "destroy": "turbo run destroy --filter=@my-app/infra --",
    "destroy:dev": "bun run destroy -- --stage dev",
    "destroy:test": "bun run destroy -- --stage test",
    "destroy:prod": "bun run destroy -- --stage prod",
    "e2e:clean": "node ./scripts/e2e-clean.mjs",
    "e2e:repair": "node ./scripts/e2e-repair-state.mjs",
    "check": "ultracite check",
    "ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@my-app/env": "*",
    "dotenv": "^17.3.1",
    "drizzle-orm": "1.0.0-beta.15-859cf75",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@cloudflare/workers-types": "^4.20260302.0",
    "@my-app/config": "*",
    "@types/node": "^22.19.11",
    "alchemy": "0.85.1",
    "turbo": "^2.8.10",
    "typescript": "^5.9.3",
    "ultracite": "7.2.3",
    "ytdlp-nodejs": "^3.4.4"
  },
  "packageManager": "bun@1.2.22",
  "overrides": {
    "drizzle-orm": "1.0.0-beta.15-859cf75"
  }
}
