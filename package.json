{
  "name": "my-better-t-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @my-better-t-app/db db:push",
    "db:generate": "turbo -F @my-better-t-app/db db:generate",
    "deploy": "turbo -F @my-better-t-app/infra deploy",
    "destroy": "turbo -F @my-better-t-app/infra destroy",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "ruler:apply": "npx @intellectronica/ruler@latest apply --local-only"
  },
  "dependencies": {
    "@my-better-t-app/env": "*",
    "dotenv": "^17.2.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@cloudflare/workers-types": "^4.20251213.0",
    "@my-better-t-app/config": "*",
    "@types/node": "^22.13.14",
    "turbo": "^2.6.3",
    "typescript": "^5",
    "ultracite": "7.1.3"
  },
  "packageManager": "npm@11.7.0"
}
