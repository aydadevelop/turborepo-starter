# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myapp

# Auth
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3003
SERVER_URL=http://localhost:3000

# AI (assistant)
OPEN_ROUTER_API_KEY=
AI_MODEL=openai/gpt-5-nano:nitro

# Payments (optional)
POLAR_ACCESS_TOKEN=
POLAR_SUCCESS_URL=
POLAR_PRODUCT_ID=
CLOUDPAYMENTS_PUBLIC_ID=
CLOUDPAYMENTS_API_SECRET=

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_BOT_API_BASE_URL=

# Storage
STORAGE_BACKEND=s3
STORAGE_PUBLIC_BASE_URL=http://localhost:8333/listing-public-v1
STORAGE_LOCAL_DIR=./.data/storage/listing-public-v1
STORAGE_S3_ENDPOINT=http://localhost:8333
STORAGE_S3_REGION=us-east-1
STORAGE_S3_BUCKET=listing-public-v1
STORAGE_S3_ACCESS_KEY_ID=seaweedfs-access-key
STORAGE_S3_SECRET_ACCESS_KEY=seaweedfs-secret-key
STORAGE_S3_FORCE_PATH_STYLE=1
STORAGE_SIGNED_URL_TTL_SECONDS=900

# Public env vars for SvelteKit
PUBLIC_SERVER_URL=http://localhost:3000
PUBLIC_ASSISTANT_URL=http://localhost:3001
