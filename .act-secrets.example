# .act-secrets.example — copy to .act-secrets and fill in real values.
# .act-secrets is gitignored — never commit real credentials.
#
# These mirror the secrets set by `pulumi up` → sync-ci-secrets on the VPS.
# To get current values:
#   cd infra/pulumi && PULUMI_CONFIG_PASSPHRASE="" pulumi stack output --show-secrets

# ── VPS SSH connection ──────────────────────────────────────────────────────
SSH_HOST=81.177.159.75
SSH_USER=root
SSH_PORT=22

# ── SSH private key (base64-encoded ED25519 key generated by Pulumi) ────────
# Get via: cd infra/pulumi && PULUMI_CONFIG_PASSPHRASE="" pulumi stack output --show-secrets
# Then base64-encode the private key and paste here.
SSH_PRIVATE_KEY_B64=

# ── GHCR authentication (for act to pull/push images locally) ───────────────
GITHUB_TOKEN=

# ── Gitleaks (optional — skip secret scan if not licensed) ──────────────────
GITLEAKS_LICENSE=
