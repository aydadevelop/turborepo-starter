{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"useTabs": true,
	"tabWidth": 2,
	"printWidth": 80,
	"singleQuote": false,
	"jsxSingleQuote": false,
	"quoteProps": "as-needed",
	"trailingComma": "all",
	"semi": true,
	"arrowParens": "always",
	"bracketSameLine": false,
	"bracketSpacing": true,
	"ignorePatterns": [
		"**/bun.lock",
		"**/.next",
		"**/dist",
		"**/.turbo",
		"**/dev-dist",
		"**/.zed",
		"**/.vscode",
		"**/.secrets",
		"**/routeTree.gen.ts",
		"**/src-tauri",
		"**/.nuxt",
		"bts.jsonc",
		"**/.expo",
		"**/legacy",
		"**/docs",
		"**/tmp",
		"**/playwright-report",
		"**/.svelte-kit",
		"**/playwright-report",
		"**/test-results",
		"**/.source",
		"**/convex/_generated",
		"**/.git",
		"**/.agents",
		"**/.github",
		"**/.vscode",
		"**/scripts",
		"**/codex"
	]
}
