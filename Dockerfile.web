# Dockerfile for SvelteKit web app (adapter-node)
#
# Uses `turbo prune --docker` so the package.json list never needs manual updates.

ARG NODE_VERSION=22
ARG BUN_VERSION=1.3.10
FROM oven/bun:${BUN_VERSION} AS base
WORKDIR /app

# ── prune: isolate the web workspace and its dependencies ──────────────────
FROM base AS prune
RUN bun add -g turbo@^2
COPY . .
RUN turbo prune web --docker

# ── deps: install ALL dependencies (devDeps needed for build) ──────────────
FROM base AS deps
COPY --from=prune /app/out/json/ .
RUN env -u CI bun install

# ── build ──────────────────────────────────────────────────────────────────
FROM deps AS build
COPY --from=prune /app/out/full/ .
WORKDIR /app/apps/web
RUN bun run build

# ── runtime ────────────────────────────────────────────────────────────────
# Reuse the bun image (already pulled in base stage — no extra network pull).
FROM oven/bun:${BUN_VERSION} AS runtime
# oven/bun ships with a non-root 'bun' user (uid 1000) — use it directly.
WORKDIR /app

# Ensure Dokku picks up the healthchecks for zero-downtime deployment
COPY --from=build --chown=bun:bun /app/apps/web/app.json ./app.json

COPY --from=build --chown=bun:bun /app/apps/web/build ./build
# Bun treats pruned installs as frozen in CI, and `bun install --production`
# still tries to rewrite the pruned lockfile. Reuse the already-resolved deps
# layer for runtime instead of re-installing inside the ephemeral Docker workspace.
COPY --from=deps --chown=bun:bun /app/node_modules ./node_modules

USER bun
ENV NODE_ENV=production
EXPOSE 3000
CMD ["bun", "run", "build/index.js"]
