{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalPassThroughEnv": ["ALCHEMY_TUNNEL", "BASE_PATH"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".svelte-kit/**", "build/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:fix": {
      "cache": false
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "env": [
        "PLAYWRIGHT_BASE_URL",
        "PLAYWRIGHT_SERVER_URL",
        "PLAYWRIGHT_ASSISTANT_URL",
        "PLAYWRIGHT_MANAGED_SERVERS",
        "PLAYWRIGHT_REUSE_SERVERS",
        "PLAYWRIGHT_SKIP_SEED",
        "PLAYWRIGHT_SEED_SCENARIO",
        "PLAYWRIGHT_SEED_ANCHOR_DATE",
        "PLAYWRIGHT_WEB_SERVER_COMMAND",
        "PLAYWRIGHT_BACKEND_SERVER_COMMAND"
      ],
      "cache": false
    },
    "test:integration:calendar": {
      "env": [
        "RUN_NETWORK_TESTS",
        "GOOGLE_CALENDAR_CREDENTIALS_PATH",
        "GOOGLE_CALENDAR_TEST_FULL_ACCESS_ID",
        "GOOGLE_CALENDAR_TEST_READ_ONLY_ID",
        "GOOGLE_CALENDAR_TEST_NO_ACCESS_ID"
      ],
      "cache": false
    },
    "test:integration:calendar:webhook": {
      "env": [
        "RUN_NETWORK_TESTS",
        "RUN_WEBHOOK_NETWORK_TESTS",
        "GOOGLE_CALENDAR_CREDENTIALS_PATH",
        "GOOGLE_CALENDAR_TEST_FULL_ACCESS_ID",
        "GOOGLE_CALENDAR_TEST_READ_ONLY_ID",
        "GOOGLE_CALENDAR_TEST_NO_ACCESS_ID",
        "GOOGLE_CALENDAR_TEST_WEBHOOK_URL",
        "GOOGLE_CALENDAR_WEBHOOK_TEST_TOKEN"
      ],
      "cache": false
    },
    "dev": {
      "env": [
        "ALCHEMY_SKIP_WEB",
        "ALCHEMY_E2E",
        "STAGE",
        "SERVER_PORT",
        "NOTIFICATIONS_PORT",
        "ASSISTANT_PORT",
        "PLAYWRIGHT_BASE_URL",
        "PLAYWRIGHT_SERVER_URL",
        "PLAYWRIGHT_ASSISTANT_URL",
        "PUBLIC_SERVER_URL",
        "PUBLIC_ASSISTANT_URL"
      ],
      "cache": false,
      "persistent": true
    },
    "db:push": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "db:migrate": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:reset:local": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    },
    "deploy": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "destroy": {
      "cache": false
    }
  }
}
