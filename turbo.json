{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalPassThroughEnv": ["ALCHEMY_TUNNEL", "BASE_PATH"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".svelte-kit/**", "build/**"]
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "//#format-and-lint": {},
    "//#format-and-lint:fix": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["transit"]
    },
    "lint:fix": {
      "cache": false
    },
    "check-types": {
      "dependsOn": ["transit"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:e2e": {
      "dependsOn": ["transit"],
      "passThroughEnv": ["PLAYWRIGHT_*", "CI"],
      "outputs": ["test-results/**", "playwright-report/**"]
    },
    "test:e2e:ui": {
      "dependsOn": ["transit"],
      "passThroughEnv": ["PLAYWRIGHT_*", "CI"],
      "cache": false
    },
    "test:perf": {
      "dependsOn": ["transit"],
      "passThroughEnv": ["PLAYWRIGHT_*", "CI"],
      "cache": false
    },
    "test:perf:vitals": {
      "dependsOn": ["transit"],
      "passThroughEnv": ["PLAYWRIGHT_*", "CI"],
      "cache": false
    },
    "test:perf:memory": {
      "dependsOn": ["transit"],
      "passThroughEnv": ["PLAYWRIGHT_*", "CI"],
      "cache": false
    },
    "test:perf:lighthouse": {
      "dependsOn": ["transit"],
      "passThroughEnv": ["PLAYWRIGHT_*", "CI"],
      "cache": false
    },
    "test:perf:scroll": {
      "dependsOn": ["transit"],
      "passThroughEnv": ["PLAYWRIGHT_*", "CI"],
      "cache": false
    },
    "test:integration:calendar": {
      "env": [
        "RUN_NETWORK_TESTS",
        "GOOGLE_CALENDAR_CREDENTIALS_PATH",
        "GOOGLE_CALENDAR_TEST_FULL_ACCESS_ID",
        "GOOGLE_CALENDAR_TEST_READ_ONLY_ID",
        "GOOGLE_CALENDAR_TEST_NO_ACCESS_ID"
      ],
      "cache": false
    },
    "test:integration:calendar:webhook": {
      "env": [
        "RUN_NETWORK_TESTS",
        "RUN_WEBHOOK_NETWORK_TESTS",
        "GOOGLE_CALENDAR_CREDENTIALS_PATH",
        "GOOGLE_CALENDAR_TEST_FULL_ACCESS_ID",
        "GOOGLE_CALENDAR_TEST_READ_ONLY_ID",
        "GOOGLE_CALENDAR_TEST_NO_ACCESS_ID",
        "GOOGLE_CALENDAR_TEST_WEBHOOK_URL",
        "GOOGLE_CALENDAR_WEBHOOK_TEST_TOKEN"
      ],
      "cache": false
    },
    "dev": {
      "env": [
        "ALCHEMY_SKIP_WEB",
        "ALCHEMY_E2E",
        "STAGE",
        "SERVER_PORT",
        "NOTIFICATIONS_PORT",
        "ASSISTANT_PORT",
        "PLAYWRIGHT_BASE_URL",
        "PLAYWRIGHT_SERVER_URL",
        "PLAYWRIGHT_ASSISTANT_URL",
        "OPEN_ROUTER_API_KEY",
        "PUBLIC_SERVER_URL",
        "PUBLIC_ASSISTANT_URL"
      ],
      "cache": false,
      "persistent": true
    },
    "dev:vite": {
      "cache": false,
      "persistent": true
    },
    "db:push": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "db:migrate": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:reset:local": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    },
    "deploy": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "destroy": {
      "cache": false
    }
  }
}
