{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": ["CI"],
  "globalPassThroughEnv": [
    "ALCHEMY_TUNNEL",
    "ALCHEMY_PASSWORD",
    "ALCHEMY_STATE_TOKEN",
    "ALCHEMY_E2E",
    "BASE_PATH",
    "STAGE",
    "CLOUDFLARE_API_TOKEN",
    "CLOUDFLARE_API_KEY",
    "CLOUDFLARE_ACCOUNT_ID",
    "CF_ACCOUNT_ID",
    "CLOUDFLARE_EMAIL",
    "CLOUDFLARE_PROFILE",
    "CLOUDFLARE_WORKERS_SUBDOMAIN",
    "CLOUDFLARE_BASE_URL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "SERVER_URL",
    "ASSISTANT_URL",
    "CORS_ORIGIN",
    "OPEN_ROUTER_API_KEY",
    "AI_MODEL",
    "POLAR_ACCESS_TOKEN",
    "CLOUDPAYMENTS_PUBLIC_ID",
    "PUBLIC_CLOUDPAYMENTS_PUBLIC_ID",
    "CLOUDPAYMENTS_API_SECRET",
    "TELEGRAM_BOT_TOKEN",
    "TELEGRAM_BOT_USERNAME",
    "TELEGRAM_BOT_API_BASE_URL",
    "NGROK_AUTH_TOKEN",
    "NGROK_AUTHTOKEN",
    "NGROK_DOMAIN_NAME"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".svelte-kit/**", "build/**"]
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "//#format-and-lint": {},
    "//#format-and-lint:fix": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["transit"]
    },
    "lint:fix": {
      "cache": false
    },
    "check-types": {
      "dependsOn": ["transit"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:e2e": {
      "cache": false,
      "passThroughEnv": ["PLAYWRIGHT_*", "BASE_PATH"]
    },
    "test:e2e:ui": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["PLAYWRIGHT_*", "BASE_PATH"]
    },
    "dev": {
      "env": [
        "ALCHEMY_SKIP_WEB",
        "STAGE",
        "SERVER_PORT",
        "NOTIFICATIONS_PORT",
        "ASSISTANT_PORT",
        "OPEN_ROUTER_API_KEY",
        "PUBLIC_SERVER_URL",
        "PUBLIC_ASSISTANT_URL"
      ],
      "cache": false,
      "persistent": true
    },
    "dev:vite": {
      "cache": false,
      "persistent": true
    },
    "db:push": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "db:migrate": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:reset:local": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    },
    "deploy": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "destroy": {
      "cache": false
    }
  }
}
