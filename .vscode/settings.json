  },
  "[typescript]": {
    "editor.defaultFormatter": "oxc.vscode-oxc"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.vscode-oxc"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "oxc.vscode-oxc"
  },
  "[json]": {
    "editor.defaultFormatter": "oxc.vscode-oxc"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "oxc.vscode-oxc"
  },
  "[svelte]": {
    "editor.defaultFormatter": "svelte.svelte-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
