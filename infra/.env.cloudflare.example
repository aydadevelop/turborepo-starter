# infra/.env.cloudflare — Cloudflare API credentials (gitignored)
#
# 1. CF_API_TOKEN: Create at https://dash.cloudflare.com/profile/api-tokens
#    → "Create Token" → "Edit zone DNS" template → scope to ayda.studio zone
#
# 2. CF_ZONE_ID: Cloudflare dashboard → ayda.studio → Overview → right sidebar
#    (32-char hex string)

CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_ZONE_ID=your-zone-id-for-ayda-studio
