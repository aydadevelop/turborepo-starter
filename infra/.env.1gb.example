# infra/.env.1gb — 1gb.ru API credentials (gitignored)
#
# Get these from your 1gb.ru account:
# 1. ONE_GB_LOGIN: your account login (e.g. boatrentbot)
# 2. ONE_GB_SALT: Settings → API → Salt (https://1gb.ru/settings)
#
# Copy this file to .env.1gb and fill in values.

ONE_GB_LOGIN=your-login
ONE_GB_OTP=your-api-password-from-kabinet

# Optional: pre-acquired persistent token (skips OTP auth if set)
# Get by running: source infra/scripts/1gb-auth.sh && echo $TOKEN
# ONE_GB_TOKEN=
