{
  "__inputs": [],
  "__requires": [
    { "type": "datasource", "id": "tempo", "name": "Tempo", "version": "1.0.0" }
  ],
  "uid": "trace-explorer",
  "title": "Trace Explorer",
  "description": "Search and inspect traces via Tempo — replacement for Drilldown Traces view",
  "tags": ["traces", "tempo", "explorer"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "custom",
        "query": "server,assistant,notifications",
        "includeAll": true,
        "allValue": "",
        "multi": false,
        "current": { "selected": false, "text": "All", "value": "$__all" }
      },
      {
        "name": "minDuration",
        "label": "Min Duration",
        "type": "custom",
        "query": ",100ms,500ms,1s,2s,5s",
        "includeAll": false,
        "multi": false,
        "current": { "selected": false, "text": "", "value": "" }
      },
      {
        "name": "status",
        "label": "Status",
        "type": "custom",
        "query": ",error,ok,unset",
        "includeAll": false,
        "multi": false,
        "current": { "selected": false, "text": "", "value": "" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Trace Search",
      "description": "Search traces with TraceQL. Use the variables above to filter, or write raw TraceQL.",
      "type": "table",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Duration", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Trace ID" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View trace",
                    "url": "/explore?orgId=1&left=%7B%22datasource%22:%22tempo%22,%22queries%22:%5B%7B%22refId%22:%22A%22,%22datasource%22:%7B%22type%22:%22tempo%22,%22uid%22:%22tempo%22%7D,%22queryType%22:%22traceql%22,%22query%22:%22${__value.raw}%22%7D%5D%7D",
                    "targetBlank": true
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Duration" },
            "properties": [
              { "id": "unit", "value": "ns" }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "nativeSearch",
          "serviceName": "$service",
          "minDuration": "$minDuration",
          "search": "",
          "limit": 50,
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Trace Search (all services)",
      "description": "Shows recent root spans across all services. Click a Trace ID to open in Explore.",
      "type": "table",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Start time", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Trace ID" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View trace",
                    "url": "/explore?orgId=1&left=%7B%22datasource%22:%22tempo%22,%22queries%22:%5B%7B%22refId%22:%22A%22,%22datasource%22:%7B%22type%22:%22tempo%22,%22uid%22:%22tempo%22%7D,%22queryType%22:%22traceql%22,%22query%22:%22${__value.raw}%22%7D%5D%7D",
                    "targetBlank": true
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Duration" },
            "properties": [
              { "id": "unit", "value": "ns" }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "nativeSearch",
          "limit": 50,
          "refId": "A"
        }
      ]
    }
  ]
}
