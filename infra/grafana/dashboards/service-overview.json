{
  "__inputs": [],
  "__requires": [
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "tempo", "name": "Tempo", "version": "1.0.0" }
  ],
  "uid": "service-overview",
  "title": "Service Overview (RED)",
  "description": "Rate / Error / Duration from span-metrics generated by Tempo",
  "tags": ["traces", "RED", "services"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(traces_spanmetrics_calls_total, service)",
        "query": "label_values(traces_spanmetrics_calls_total, service)",
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate by Service",
      "description": "Requests per second from span-metrics",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by(service) (rate(traces_spanmetrics_calls_total{service=~\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate by Service",
      "description": "Error requests per second (status_code=STATUS_CODE_ERROR)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 15 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by(service) (rate(traces_spanmetrics_calls_total{service=~\"$service\", span_kind=\"SPAN_KIND_SERVER\", status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Ratio (%) by Service",
      "description": "Percentage of requests that are errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "fillOpacity": 15 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by(service) (rate(traces_spanmetrics_calls_total{service=~\"$service\", span_kind=\"SPAN_KIND_SERVER\", status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / sum by(service) (rate(traces_spanmetrics_calls_total{service=~\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "P95 Latency by Service",
      "description": "95th percentile duration from span-metrics histogram",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 15 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by(service, le) (rate(traces_spanmetrics_duration_seconds_bucket{service=~\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval])))",
          "legendFormat": "{{service}} p95",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "P50 / P90 / P99 Latency by Service",
      "description": "Multi-quantile latency view",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by(service, le) (rate(traces_spanmetrics_duration_seconds_bucket{service=~\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval])))",
          "legendFormat": "{{service}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, sum by(service, le) (rate(traces_spanmetrics_duration_seconds_bucket{service=~\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval])))",
          "legendFormat": "{{service}} p90",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by(service, le) (rate(traces_spanmetrics_duration_seconds_bucket{service=~\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval])))",
          "legendFormat": "{{service}} p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "title": "Top Endpoints by Call Count",
      "description": "Most frequently called span names (routes/procedures)",
      "type": "bargauge",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "topk(15, sum by(span_name) (increase(traces_spanmetrics_calls_total{service=~\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[5m])))",
          "legendFormat": "{{span_name}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 7,
      "title": "Slowest Endpoints (P95)",
      "description": "Endpoints with highest P95 latency",
      "type": "bargauge",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "topk(15, histogram_quantile(0.95, sum by(span_name, le) (rate(traces_spanmetrics_duration_seconds_bucket{service=~\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval]))))",
          "legendFormat": "{{span_name}}",
          "refId": "A",
          "instant": true
        }
      ]
    }
  ]
}
