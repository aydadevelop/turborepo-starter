{
	"__inputs": [],
	"__requires": [
		{
			"type": "datasource",
			"id": "tempo",
			"name": "Tempo",
			"version": "1.0.0"
		},
		{
			"type": "datasource",
			"id": "prometheus",
			"name": "Prometheus",
			"version": "1.0.0"
		}
	],
	"uid": "service-map",
	"title": "Service Map & Dependencies",
	"description": "Node graph showing service-to-service dependencies from Tempo service_graphs",
	"tags": ["traces", "services", "topology"],
	"schemaVersion": 39,
	"version": 1,
	"refresh": "30s",
	"time": { "from": "now-30m", "to": "now" },
	"templating": { "list": [] },
	"panels": [
		{
			"id": 1,
			"title": "Service Map",
			"description": "Service dependency graph built from traces_service_graph_* metrics",
			"type": "nodeGraph",
			"gridPos": { "h": 18, "w": 24, "x": 0, "y": 0 },
			"datasource": { "type": "tempo", "uid": "tempo" },
			"targets": [
				{
					"datasource": { "type": "tempo", "uid": "tempo" },
					"queryType": "serviceMap",
					"refId": "A"
				}
			]
		},
		{
			"id": 2,
			"title": "Service-to-Service Request Rate",
			"description": "Calls between services from service_graphs",
			"type": "timeseries",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"options": {
				"legend": {
					"displayMode": "table",
					"placement": "right",
					"calcs": ["mean", "max"]
				}
			},
			"fieldConfig": {
				"defaults": { "unit": "reqps", "custom": { "fillOpacity": 15 } },
				"overrides": []
			},
			"targets": [
				{
					"expr": "sum by(client, server) (rate(traces_service_graph_request_total[$__rate_interval]))",
					"legendFormat": "{{client}} → {{server}}",
					"refId": "A"
				}
			]
		},
		{
			"id": 3,
			"title": "Service-to-Service Error Rate",
			"description": "Failed calls between services",
			"type": "timeseries",
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"options": {
				"legend": {
					"displayMode": "table",
					"placement": "right",
					"calcs": ["mean", "max"]
				}
			},
			"fieldConfig": {
				"defaults": {
					"unit": "reqps",
					"custom": { "fillOpacity": 15 },
					"color": { "fixedColor": "red", "mode": "fixed" }
				},
				"overrides": []
			},
			"targets": [
				{
					"expr": "sum by(client, server) (rate(traces_service_graph_request_failed_total[$__rate_interval]))",
					"legendFormat": "{{client}} → {{server}}",
					"refId": "A"
				}
			]
		},
		{
			"id": 4,
			"title": "Service-to-Service P95 Latency",
			"description": "95th percentile latency between service pairs",
			"type": "timeseries",
			"gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"options": {
				"legend": {
					"displayMode": "table",
					"placement": "right",
					"calcs": ["mean", "max"]
				}
			},
			"fieldConfig": {
				"defaults": { "unit": "s", "custom": { "fillOpacity": 10 } },
				"overrides": []
			},
			"targets": [
				{
					"expr": "histogram_quantile(0.95, sum by(client, server, le) (rate(traces_service_graph_request_server_seconds_bucket[$__rate_interval])))",
					"legendFormat": "{{client}} → {{server}} p95",
					"refId": "A"
				}
			]
		}
	]
}
