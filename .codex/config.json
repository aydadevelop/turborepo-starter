{
  "mcpServers": {
    "github": {
      "url": "https://api.githubcopilot.com/mcp/",
      "type": "remote",
      "bearer_token_env_var": "GITHUB_PAT_TOKEN"
    },
    "context7": {
      "command": "bunx",
      "args": ["@upstash/context7-mcp"],
      "type": "stdio"
    },
    "cloudflare": {
      "command": "bunx",
      "args": ["mcp-remote", "https://docs.mcp.cloudflare.com/sse"],
      "type": "stdio"
    },

    "better-auth": {
      "command": "bunx",
      "args": [
        "mcp-remote@latest",
        "https://mcp.chonkie.ai/better-auth/better-auth-builder/mcp"
      ],
      "type": "remote"
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ultracite fix"
          }
        ]
      }
    ]
  }
}
