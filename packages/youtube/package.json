{
  "name": "@my-app/youtube",
  "private": true,
  "type": "module",
  "exports": {
    "./search": {
      "default": "./src/search.ts"
    },
    "./subtitles": {
      "default": "./src/subtitles.ts"
    },
    "./metadata": {
      "default": "./src/metadata.ts"
    },
    "./download-audio": {
      "default": "./src/download-audio.ts"
    },
    "./transcribe": {
      "default": "./src/transcribe.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "cd ../.. && biome check --config-path biome.json packages/youtube",
    "lint:fix": "cd ../.. && biome check --config-path biome.json packages/youtube --write",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "openai": "^6.22.0",
    "ytdlp-nodejs": "^3.4.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@my-app/config": "*",
    "@my-app/vitest-config": "*",
    "typescript": "^5",
    "ultracite": "^7.2.3",
    "vitest": "^3.2.4"
  }
}
