{
  "name": "@my-app/ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "svelte": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "svelte": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./components/*": {
      "types": "./src/components/*/index.ts",
      "svelte": "./src/components/*/index.ts",
      "default": "./src/components/*/index.ts"
    },
    "./lib/*": {
      "types": "./src/lib/*.ts",
      "svelte": "./src/lib/*.ts",
      "default": "./src/lib/*.ts"
    },
    "./hooks/*": {
      "types": "./src/hooks/*.ts",
      "svelte": "./src/hooks/*.ts",
      "default": "./src/hooks/*.ts"
    },
    "./styles/*": {
      "default": "./src/styles/*"
    }
  },
  "scripts": {
    "check-types": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "cd ../.. && biome check --config-path biome.json packages/ui",
    "lint:fix": "cd ../.. && biome check --config-path biome.json packages/ui --write"
  },
  "dependencies": {
    "@my-app/tailwind-config": "workspace:*",
    "bits-ui": "^2.15.5",
    "clsx": "^2.1.1",
    "layerchart": "2.0.0-next.46",
    "lucide-svelte": "^0.563.0",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@internationalized/date": "^3.11.0",
    "@lucide/svelte": "^0.561.0",
    "@my-app/config": "workspace:*",
    "svelte": "^5.38.1",
    "svelte-check": "^4.3.1",
    "typescript": "^5",
    "ultracite": "^7.2.3"
  }
}
