{
	"name": "@my-app/payment",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./src/index.ts"
		},
		"./webhooks": {
			"types": "./dist/webhooks/index.d.ts",
			"default": "./src/webhooks/index.ts"
		},
		"./webhooks/*": {
			"types": "./dist/webhooks/*.d.ts",
			"default": "./src/webhooks/*.ts"
		}
	},
	"scripts": {
		"build-types": "tsc --emitDeclarationOnly -p tsconfig.json",
		"check-types": "tsc --noEmit -p tsconfig.json",
		"lint": "cd ../.. && oxlint packages/payment",
		"lint:fix": "cd ../.. && oxlint --fix packages/payment",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest --watch"
	},
	"dependencies": {
		"@my-app/db": "workspace:*",
		"@my-app/events": "workspace:*",
		"drizzle-orm": "1.0.0-beta.16-2ffd1a5",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@my-app/config": "workspace:*",
		"@my-app/vitest-config": "workspace:*",
		"typescript": "^5",
		"vitest": "^4.0.18"
	}
}
