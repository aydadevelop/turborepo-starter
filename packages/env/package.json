{
	"name": "@my-app/env",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		"./loader": {
			"types": "./dist/loader.d.ts",
			"default": "./src/loader.ts"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"default": "./src/server.ts"
		},
		"./assistant": {
			"types": "./dist/assistant.d.ts",
			"default": "./src/assistant.ts"
		},
		"./web": {
			"types": "./dist/web.d.ts",
			"default": "./src/web.ts"
		}
	},
	"scripts": {
		"build-types": "tsc --emitDeclarationOnly -p tsconfig.json",
		"check-types": "tsc --noEmit -p tsconfig.json",
		"lint": "cd ../.. && oxlint packages/env",
		"lint:fix": "cd ../.. && oxlint --fix packages/env"
	},
	"dependencies": {
		"@t3-oss/env-core": "^0.13.1",
		"dotenv": "^17.2.2",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@my-app/config": "workspace:*",
		"@types/node": "^22.19.11",
		"typescript": "^5"
	}
}
