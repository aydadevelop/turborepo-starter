{
  "name": "@my-app/api",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    },
    "./contracts/*": {
      "default": "./src/contracts/*.ts"
    },
    "./payments/webhooks": {
      "default": "./src/payments/webhooks/index.ts"
    },
    "./payments/webhooks/*": {
      "default": "./src/payments/webhooks/*.ts"
    },
    "./tasks/*": {
      "default": "./src/tasks/*.ts"
    },
    "./routers": {
      "default": "./src/routers/index.ts"
    },
    "./routers/*": {
      "default": "./src/routers/*.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "cd ../.. && biome check --config-path biome.json packages/api",
    "lint:fix": "cd ../.. && biome check --config-path biome.json packages/api --write",
    "test": "vitest run",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@my-app/auth": "*",
    "@my-app/db": "*",
    "@my-app/env": "*",
    "@my-app/notifications": "*",
    "@orpc/server": "^1.12.2",
    "drizzle-orm": "1.0.0-beta.15-859cf75",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@my-app/config": "*",
    "@my-app/vitest-config": "*",
    "hono": "^4.8.2",
    "typescript": "^5",
    "ultracite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
