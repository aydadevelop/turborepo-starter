{
	"name": "@my-app/api",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./src/index.ts"
		},
		"./*": {
			"types": "./dist/*.d.ts",
			"default": "./src/*.ts"
		},
		"./tasks/*": {
			"types": "./dist/tasks/*.d.ts",
			"default": "./src/tasks/*.ts"
		},
		"./services/*": {
			"types": "./dist/services/*.d.ts",
			"default": "./src/services/*.ts"
		},
		"./handlers": {
			"types": "./dist/handlers/index.d.ts",
			"default": "./src/handlers/index.ts"
		},
		"./handlers/*": {
			"types": "./dist/handlers/*.d.ts",
			"default": "./src/handlers/*.ts"
		}
	},
	"scripts": {
		"build-types": "tsc --emitDeclarationOnly -p tsconfig.json",
		"check-types": "tsc --noEmit -p tsconfig.json",
		"lint": "cd ../.. && oxlint packages/api",
		"lint:fix": "cd ../.. && oxlint --fix packages/api",
		"test": "vitest run",
		"test:watch": "vitest --watch"
	},
	"dependencies": {
		"@my-app/api-contract": "workspace:*",
		"@my-app/auth": "workspace:*",
		"@my-app/booking": "workspace:*",
		"@my-app/calendar": "workspace:*",
		"@my-app/catalog": "workspace:*",
		"@my-app/db": "workspace:*",
		"@my-app/env": "workspace:*",
		"@my-app/events": "workspace:*",
		"@my-app/notifications": "workspace:*",
		"@my-app/organization": "workspace:*",
		"@my-app/payment": "workspace:*",
		"@my-app/pricing": "workspace:*",
		"@my-app/promotions": "workspace:*",
		"@my-app/queue": "workspace:*",
		"@my-app/support": "workspace:*",
		"@my-app/telemetry": "workspace:*",
		"@my-app/workflows": "workspace:*",
		"@orpc/server": "^1.12.2",
		"drizzle-orm": "1.0.0-beta.16-2ffd1a5",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@my-app/config": "workspace:*",
		"@my-app/vitest-config": "workspace:*",
		"@types/node": "^22.0.0",
		"hono": "^4.8.2",
		"typescript": "^5",
		"vitest": "^4.0.18"
	}
}
