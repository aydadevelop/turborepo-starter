    "@orpc/server": "^1.12.2",
    "@orpc/zod": "^1.12.2",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.45.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@full-stack-cf-app/config": "*",
    "@full-stack-cf-app/vitest-config": "*",
    "hono": "^4.8.2",
    "typescript": "^5",
    "vitest": "^3.2.4"
