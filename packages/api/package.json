{
  "name": "@my-app/api",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    },
    "./payments/webhooks": {
      "default": "./src/payments/webhooks/index.ts"
    },
    "./payments/webhooks/*": {
      "default": "./src/payments/webhooks/*.ts"
    },
    "./tasks/*": {
      "default": "./src/tasks/*.ts"
    },
    "./services/*": {
      "default": "./src/services/*.ts"
    },
    "./handlers": {
      "default": "./src/handlers/index.ts"
    },
    "./handlers/*": {
      "default": "./src/handlers/*.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "cd ../.. && biome check --config-path biome.json packages/api",
    "lint:fix": "cd ../.. && biome check --config-path biome.json packages/api --write",
    "test": "vitest run",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@my-app/api-contract": "workspace:*",
    "@my-app/auth": "workspace:*",
    "@my-app/db": "workspace:*",
    "@my-app/env": "workspace:*",
    "@my-app/notifications": "workspace:*",
    "@my-app/queue": "workspace:*",
    "@orpc/server": "^1.12.2",
    "drizzle-orm": "1.0.0-beta.16-2ffd1a5",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@my-app/config": "workspace:*",
    "@my-app/vitest-config": "workspace:*",
    "@types/node": "^22.0.0",
    "hono": "^4.8.2",
    "typescript": "^5",
    "ultracite": "^7.2.3",
    "vitest": "^4.0.18"
  }
}
