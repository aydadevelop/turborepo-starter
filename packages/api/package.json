{
  "name": "@full-stack-cf-app/api",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    },
    "./routers": {
      "default": "./src/routers/index.ts"
    },
    "./routers/*": {
      "default": "./src/routers/*.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "cd ../.. && biome check --config-path biome.json packages/api",
    "lint:fix": "cd ../.. && biome check --config-path biome.json packages/api --write",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:integration:calendar": "RUN_NETWORK_TESTS=1 vitest run src/__tests__/calendar-google.integration.test.ts",
    "test:integration:calendar:webhook": "RUN_NETWORK_TESTS=1 RUN_WEBHOOK_NETWORK_TESTS=1 vitest run src/__tests__/calendar-google.integration.test.ts"
  },
  "dependencies": {
    "@full-stack-cf-app/auth": "*",
    "@full-stack-cf-app/db": "*",
    "@full-stack-cf-app/env": "*",
    "@full-stack-cf-app/notifications": "*",
    "@orpc/server": "^1.12.2",
    "drizzle-orm": "1.0.0-beta.15-859cf75",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@full-stack-cf-app/config": "*",
    "@full-stack-cf-app/vitest-config": "*",
    "hono": "^4.8.2",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
