{
  "name": "@my-app/storage",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "cd ../.. && biome check --config-path biome.json packages/storage",
    "lint:fix": "cd ../.. && biome check --config-path biome.json packages/storage --write",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.940.0",
    "@aws-sdk/s3-request-presigner": "^3.940.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@my-app/config": "workspace:*",
    "@my-app/vitest-config": "workspace:*",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
