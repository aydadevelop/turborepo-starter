{
  "name": "@my-app/auth",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    },
    "./test": {
      "default": "./src/test/index.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit -p tsconfig.json --composite false --declaration false --declarationMap false",
    "lint": "cd ../.. && biome check --config-path biome.json packages/auth",
    "lint:fix": "cd ../.. && biome check --config-path biome.json packages/auth --write",
    "test": "vitest run",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.4.18",
    "@my-app/db": "*",
    "@my-app/env": "*",
    "better-auth": "^1.4.18",
    "better-auth-telegram": "^0.3.2",
    "dotenv": "^17.2.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@my-app/config": "*",
    "@my-app/vitest-config": "*",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^11.10.0",
    "typescript": "^5",
    "ultracite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
