{
  "name": "@my-app/auth",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    },
    "./test": {
      "default": "./src/test/index.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit -p tsconfig.json --composite false --declaration false --declarationMap false",
    "lint": "cd ../.. && biome check --config-path biome.json packages/auth",
    "lint:fix": "cd ../.. && biome check --config-path biome.json packages/auth --write",
    "test": "vitest run",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.5.0",
    "@my-app/db": "workspace:*",
    "@my-app/env": "workspace:*",
    "better-auth": "^1.5.0",
    "better-auth-telegram": "^1.4.0",
    "dotenv": "^17.2.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@my-app/config": "workspace:*",
    "@my-app/vitest-config": "workspace:*",
    "typescript": "^5",
    "ultracite": "^7.2.3",
    "vitest": "^4.0.18"
  }
}
