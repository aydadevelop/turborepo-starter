{
	"name": "@my-app/auth",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./src/index.ts"
		},
		"./*": {
			"types": "./dist/*.d.ts",
			"default": "./src/*.ts"
		},
		"./test": {
			"types": "./dist/test/index.d.ts",
			"default": "./src/test/index.ts"
		}
	},
	"scripts": {
		"build-types": "tsc --emitDeclarationOnly -p tsconfig.json",
		"check-types": "tsc --noEmit -p tsconfig.json --composite false --declaration false --declarationMap false",
		"lint": "cd ../.. && oxlint packages/auth",
		"lint:fix": "cd ../.. && oxlint --fix packages/auth",
		"test": "vitest run",
		"test:watch": "vitest --watch"
	},
	"dependencies": {
		"@better-auth/drizzle-adapter": "^1.5.0",
		"@better-auth/passkey": "^1.5.0",
		"@kubiks/otel-better-auth": "^2.0.2",
		"@my-app/db": "workspace:*",
		"@my-app/env": "workspace:*",
		"better-auth": "^1.5.0",
		"better-auth-telegram": "^1.4.0",
		"dotenv": "^17.2.2",
		"drizzle-orm": "1.0.0-beta.16-2ffd1a5",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@my-app/config": "workspace:*",
		"@my-app/vitest-config": "workspace:*",
		"typescript": "^5",
		"vitest": "^4.0.18"
	}
}
