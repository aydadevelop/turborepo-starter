{
  "name": "@my-app/assistant",
  "type": "module",
  "exports": {
    "./tools": {
      "default": "./src/tools.ts"
    },
    "./router": {
      "default": "./src/router.ts"
    },
    "./context": {
      "default": "./src/context.ts"
    },
    "./system-prompt": {
      "default": "./src/system-prompt.ts"
    },
    "./transport": {
      "default": "./src/transport.ts"
    }
