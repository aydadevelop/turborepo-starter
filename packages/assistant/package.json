{
  "name": "@my-app/assistant",
  "type": "module",
  "exports": {
    "./tools": {
      "default": "./src/tools.ts"
    },
    "./router": {
      "default": "./src/router.ts"
    },
    "./contract": {
      "default": "./src/contract.ts"
    },
    "./context": {
      "default": "./src/context.ts"
    },
    "./system-prompt": {
      "default": "./src/system-prompt.ts"
    },
    "./transport": {
      "default": "./src/transport.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "cd ../.. && biome check --config-path biome.json packages/assistant",
    "lint:fix": "cd ../.. && biome check --config-path biome.json packages/assistant --write",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@my-app/db": "workspace:*",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "@orpc/client": "^1.12.2",
    "@orpc/contract": "^1.13.4",
    "@orpc/server": "^1.12.2",
    "ai": "^6.0.86",
    "better-auth": "^1.5.0",
    "drizzle-orm": "1.0.0-beta.16-2ffd1a5",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@my-app/api-contract": "workspace:*",
    "@my-app/config": "workspace:*",
    "@my-app/vitest-config": "workspace:*",
    "typescript": "^5",
    "ultracite": "^7.2.3",
    "vitest": "^4.0.18"
  }
