# Alchemy Infrastructure Secrets
# Copy this file to .env

# =============================================================================
# REQUIRED - Alchemy State Encryption
# =============================================================================
# Password for encrypting local Alchemy state. Generate with: openssl rand -hex 24
ALCHEMY_PASSWORD=your-encryption-password

# =============================================================================
# REQUIRED - Cloudflare Deployment
# =============================================================================
# Cloudflare API token with Workers/D1/Pages permissions
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Cloudflare account ID (required for tunnel mode, optional for local-only dev)
# CLOUDFLARE_ACCOUNT_ID=your-account-id

# =============================================================================
# OPTIONAL - Named Tunnel (stable URLs for OAuth/webhooks)
# =============================================================================
# Set TUNNEL_DOMAIN to enable named tunnels with DNS CNAME records.
# Creates stable subdomains: {stage}.{domain} (web) + api-{stage}.{domain} (server)
# Example: TUNNEL_DOMAIN=ayda.studio → dev.ayda.studio + api-dev.ayda.studio
# Requires: CLOUDFLARE_API_TOKEN with DNS Edit + Tunnel Edit permissions
# Requires: CLOUDFLARE_ACCOUNT_ID
# Requires: cloudflared installed (brew install cloudflared)
# TUNNEL_DOMAIN=ayda.studio

# =============================================================================
# OPTIONAL - CI/CD State Store
# =============================================================================
# For GitHub Actions deployment (uses Cloudflare KV for shared state)
# ALCHEMY_STATE_TOKEN=your-alchemy-state-token

# =============================================================================
# OPTIONAL - Telemetry
# =============================================================================
# Disable Alchemy telemetry collection
ALCHEMY_TELEMETRY_DISABLED=true
