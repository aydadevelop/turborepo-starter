# Alchemy Infrastructure Secrets
# Copy this file to .env

# =============================================================================
# REQUIRED - Alchemy State Encryption
# =============================================================================
# Password for encrypting local Alchemy state. Generate with: openssl rand -hex 24
ALCHEMY_PASSWORD=your-encryption-password

# =============================================================================
# REQUIRED - Cloudflare Deployment
# =============================================================================
# Cloudflare API token with Workers/D1/Pages permissions
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# =============================================================================
# OPTIONAL - CI/CD State Store
# =============================================================================
# For GitHub Actions deployment (uses Cloudflare KV for shared state)
# ALCHEMY_STATE_TOKEN=your-alchemy-state-token

# =============================================================================
# OPTIONAL - Calendar Sync
# =============================================================================
# Google service account JSON string used by Worker runtime
# GOOGLE_CALENDAR_CREDENTIALS_JSON={"type":"service_account",...}

# Shared token validated on /webhooks/calendar/google
# GOOGLE_CALENDAR_WEBHOOK_SHARED_TOKEN=your-shared-token

# Bearer token for /internal/calendar/sync/google polling endpoint
# CALENDAR_SYNC_TASK_TOKEN=your-sync-task-token

# =============================================================================
# OPTIONAL - Telegram Notifications
# =============================================================================
# Telegram bot token for outbound notifications
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Telegram API base URL override (defaults to https://api.telegram.org)
# TELEGRAM_BOT_API_BASE_URL=https://api.telegram.org

# =============================================================================
# OPTIONAL - Telemetry
# =============================================================================
# Disable Alchemy telemetry collection
ALCHEMY_TELEMETRY_DISABLED=true
