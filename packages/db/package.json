{
  "name": "@my-app/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    },
    "./test": {
      "default": "./src/test/index.ts"
    }
  },
  "scripts": {
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio --config drizzle.config.dev.ts --host 127.0.0.1 --port 4983",
    "db:reset:local": "node ./scripts/reset-local.mjs",
    "db:bootstrap:local:e2e": "node ./scripts/bootstrap-local-e2e.mjs",
    "db:seed": "node ./scripts/seed-local.mjs",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "cd ../.. && biome check --config-path biome.json packages/db",
    "lint:fix": "cd ../.. && biome check --config-path biome.json packages/db --write",
    "test": "vitest run",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "dotenv": "^17.2.2",
    "drizzle-orm": "1.0.0-beta.15-859cf75",
    "pg": "^8.16.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@electric-sql/pglite": "^0.3.15",
    "@my-app/config": "workspace:*",
    "@my-app/vitest-config": "workspace:*",
    "@types/pg": "^8.11.14",
    "drizzle-kit": "1.0.0-beta.15-859cf75",
    "pg-mem": "^3.0.6",
    "typescript": "^5",
    "ultracite": "^7.2.3",
    "vitest": "^3.2.4"
  }
}
