{
	"name": "@my-app/db",
	"type": "module",
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./e2e/*": {
			"default": "./src/e2e/*.ts"
		},
		"./*": {
			"default": "./src/*.ts"
		},
		"./test": {
			"default": "./src/test/index.ts"
		}
	},
	"scripts": {
		"db:push": "drizzle-kit push",
		"db:migrate": "drizzle-kit migrate",
		"db:migrate:dev": "drizzle-kit migrate --config drizzle.config.dev.ts",
		"db:generate": "drizzle-kit generate",
		"db:generate:dev": "drizzle-kit generate --config drizzle.config.dev.ts",
		"db:studio": "drizzle-kit studio --config drizzle.config.dev.ts --host 127.0.0.1 --port 4983",
		"db:reset:local": "node ./scripts/reset-local.mjs",
		"db:bootstrap:local:e2e": "bun ./src/e2e/bootstrap.ts",
		"db:seed": "node ./scripts/seed-local.mjs",
		"db:seed:e2e": "bun ./src/e2e/seed.ts",
		"db:ensure:e2e:database": "bun ./src/e2e/ensure-database.ts",
		"db:snapshot:export": "node ./scripts/export-snapshot.mjs",
		"db:snapshot:import": "node ./scripts/import-snapshot.mjs",
		"db:verify:postgres": "node ./scripts/verify-postgres-baseline.mjs",
		"check-types": "tsc --noEmit -p tsconfig.json",
		"lint": "cd ../.. && oxlint packages/db",
		"lint:fix": "cd ../.. && oxlint --fix packages/db",
		"test": "vitest run",
		"test:watch": "vitest --watch"
	},
	"dependencies": {
		"@kubiks/otel-drizzle": "^1.0.0",
		"@opentelemetry/api": "^1.9.0",
		"better-auth": "^1.5.0",
		"dotenv": "^17.2.2",
		"drizzle-orm": "1.0.0-beta.16-2ffd1a5",
		"pg": "^8.16.0",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@electric-sql/pglite": "^0.3.15",
		"@my-app/config": "workspace:*",
		"@my-app/vitest-config": "workspace:*",
		"@types/pg": "^8.11.14",
		"drizzle-kit": "1.0.0-beta.16-2ffd1a5",
		"pg-mem": "^3.0.6",
		"typescript": "^5",
		"vitest": "^4.0.18"
	}
}
