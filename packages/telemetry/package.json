{
	"name": "@my-app/telemetry",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./src/index.ts"
		},
		"./logger": {
			"types": "./dist/logger.d.ts",
			"default": "./src/logger.ts"
		},
		"./tracing": {
			"types": "./dist/tracing.d.ts",
			"default": "./src/tracing.ts"
		}
	},
	"scripts": {
		"build-types": "tsc --emitDeclarationOnly -p tsconfig.json",
		"check-types": "tsc --noEmit -p tsconfig.json",
		"lint": "cd ../.. && oxlint packages/telemetry",
		"lint:fix": "cd ../.. && oxlint --fix packages/telemetry"
	},
	"dependencies": {
		"@hono/otel": "^1.1.1",
		"@hono/prometheus": "^1.0.2",
		"@opentelemetry/api": "^1.9.0",
		"@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
		"@opentelemetry/resources": "^2.6.0",
		"@opentelemetry/sdk-node": "^0.213.0",
		"@opentelemetry/semantic-conventions": "^1.40.0",
		"@orpc/otel": "^1.13.7",
		"@orpc/server": "^1.13.4",
		"prom-client": "^15.1.3"
	},
	"devDependencies": {
		"@my-app/config": "workspace:*",
		"typescript": "^5"
	}
}
