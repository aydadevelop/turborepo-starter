{
  "name": "@my-app/contaktly-widget",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/widget-client.ts"
    },
    "./constants": {
      "default": "./src/constants.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "cd ../.. && biome check --config-path biome.json packages/contaktly-widget",
    "lint:fix": "cd ../.. && biome check --config-path biome.json packages/contaktly-widget --write",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --watch"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@my-app/config": "workspace:*",
    "@my-app/vitest-config": "workspace:*",
    "typescript": "^5",
    "ultracite": "^7.2.3",
    "vitest": "^4.0.18"
  }
}
