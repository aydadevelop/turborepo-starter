{
	"extends": "@my-app/config/tsconfig.base.json",
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"composite": true,
		"declaration": true,
		"declarationMap": true,
		"outDir": "dist",
		"baseUrl": ".",
		"paths": {
			"@my-app/ai-chat/*": ["./src/*"]
		},
		"types": ["node"]
	},
	"include": ["src/**/*"],
	"exclude": ["dist", "node_modules"]
}
