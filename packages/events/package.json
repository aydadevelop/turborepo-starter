{
	"name": "@my-app/events",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"build-types": "tsc --emitDeclarationOnly -p tsconfig.json",
